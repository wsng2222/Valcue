rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Live Activity bearer tokens are server-only. Cloud Functions use the
    // Admin SDK and bypass these client rules.
    match /liveActivitySessions/{sessionId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
